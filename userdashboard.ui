       <string notr="true">QCheckBox {
    color: #1a1a2e;
    font-size: 13px;
    spacing: 8px;
    outline:none;
    border:none;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #c4c9de;
    border-radius: 4px;
    background: #ffffff;
}

QCheckBox::indicator:hover {
    border-color: #3b4fd8;
}

QCheckBox::indicator:checked {
    background: #3b4fd8;
    border-color: #3b4fd8;
    image: url(:/images/checkmark.png);
}

QCheckBox::indicator:checked:hover {
    background: #2d3fc7;
    border-color: #2d3fc7;
    image: url(:/images/checkmark.png);
}

QCheckBox:disabled {
    color: #c4c9de;
}

QCheckBox::indicator:disabled {
    border-color: #e8eaf0;
    background: #f4f5f8;
}</string>
