     <property name="styleSheet">
      <string notr="true">QTableWidget {
    border: 1px solid #e8eaf0;
    border-radius: 8px;
    background: white;
    outline: none;
    font-size: 13px;
    color: #1a1a2e;
}

QTableWidget::item {
    padding: 0px 14px;
    border: none;
    border-bottom: 1px solid #f0f2f8;
}

QTableWidget::item:selected {
    background: #eef0fb;
    color: #3b4fd8;
}

QTableWidget::item:alternate {
    background: #fafafa;
}

QHeaderView::section {
    background: #f4f5f8;
    color: #6b7280;
    font-size: 12px;
    font-weight: 600;
    padding: 0px 14px;
    height: 40px;
    border: none;
    border-bottom: 2px solid #e8eaf0;
}

QScrollBar:vertical {
    width: 6px;
    background: transparent;
}

QScrollBar::handle:vertical {
    background: #c4c9de;
    border-radius: 3px;
    min-height: 30px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}
</string>
